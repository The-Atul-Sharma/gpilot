{
  "name": "gitpilot",
  "displayName": "gitpilot",
  "description": "AI-powered git workflow inside VS Code: generate commits, create PRs with descriptions, and run AI code reviews — all from a task-oriented sidebar.",
  "version": "1.0.0",
  "publisher": "atsharma",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=24.0.0"
  },
  "categories": [
    "SCM Providers",
    "AI",
    "Other"
  ],
  "keywords": [
    "git",
    "ai",
    "commit",
    "pull request",
    "code review",
    "claude",
    "openai",
    "gemini",
    "ollama",
    "conventional commits"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build:webview": "cd ../webview && npm run build",
    "copy:webview": "node -e \"const fs=require('node:fs');const path=require('node:path');const src=path.resolve(__dirname,'../webview/dist');const dest=path.resolve(__dirname,'media/webview');fs.rmSync(dest,{recursive:true,force:true});fs.mkdirSync(dest,{recursive:true});fs.cpSync(src,dest,{recursive:true});\"",
    "build": "npm run build:webview && npm run copy:webview && tsc -p .",
    "watch": "tsc -p . --watch"
  },
  "contributes": {
    "commands": [
      {
        "command": "gitpilot.commit",
        "title": "gitpilot: Generate commit message",
        "category": "gitpilot"
      },
      {
        "command": "gitpilot.createPR",
        "title": "gitpilot: Create PR with description",
        "category": "gitpilot"
      },
      {
        "command": "gitpilot.reviewPR",
        "title": "gitpilot: Review current PR",
        "category": "gitpilot"
      },
      {
        "command": "gitpilot.fixAllBlockers",
        "title": "gitpilot: Fix all blocker comments",
        "category": "gitpilot"
      },
      {
        "command": "gitpilot.fixComment",
        "title": "gitpilot: Fix selected comment",
        "category": "gitpilot"
      },
      {
        "command": "gitpilot.switchModel",
        "title": "gitpilot: Switch AI model",
        "category": "gitpilot"
      },
      {
        "command": "gitpilot.auth",
        "title": "gitpilot: Setup or update API keys",
        "category": "gitpilot"
      },
      {
        "command": "gitpilot.showPanel",
        "title": "gitpilot: Show panel",
        "category": "gitpilot"
      },
      {
        "command": "gitpilot.status",
        "title": "gitpilot: Show status",
        "category": "gitpilot"
      },
      {
        "command": "gitpilot.toggleMode",
        "title": "gitpilot: Toggle between AI and Native Git",
        "category": "gitpilot"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitpilot",
          "title": "gitpilot",
          "icon": "media/activity-bar.png"
        }
      ]
    },
    "views": {
      "gitpilot": [
        {
          "type": "webview",
          "id": "gitpilot.panel",
          "name": "gitpilot"
        }
      ]
    },
    "menus": {
      "scm/title": [
        {
          "command": "gitpilot.commit",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "view/title": [
        {
          "command": "gitpilot.toggleMode",
          "when": "view == gitpilot.panel",
          "group": "navigation"
        },
        {
          "command": "gitpilot.auth",
          "when": "view == gitpilot.panel",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "gitpilot",
      "properties": {
        "gitpilot.defaultMode": {
          "type": "string",
          "enum": [
            "gitpilot",
            "native"
          ],
          "default": "gitpilot",
          "description": "Default sidebar mode on first activation. 'gitpilot' uses AI for commit and PR text; 'native' falls back to manual git commands."
        },
        "gitpilot.cliCommand": {
          "type": "string",
          "default": "npx gitpilot",
          "description": "Command used to invoke the gitpilot CLI from the extension. Override if gitpilot is installed under a different name or path."
        }
      }
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "keytar": "^7.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^6.0.3"
  }
}
