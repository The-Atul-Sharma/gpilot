{
  "name": "gpilot",
  "displayName": "gpilot",
  "description": "AI-powered git workflow inside VS Code: generate commits, create PRs with descriptions, and run AI code reviews — all from a task-oriented sidebar.",
  "version": "0.1.2",
  "publisher": "atsharma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-Atul-Sharma/gpilot.git"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=24.0.0"
  },
  "categories": [
    "SCM Providers",
    "AI",
    "Other"
  ],
  "keywords": [
    "git",
    "ai",
    "commit",
    "pull request",
    "code review",
    "claude",
    "openai",
    "gemini",
    "ollama",
    "conventional commits"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build:webview": "cd ../webview && npm run build",
    "copy:webview": "node -e \"const fs=require('node:fs');const path=require('node:path');const src=path.resolve(__dirname,'../webview/dist');const dest=path.resolve(__dirname,'media/webview');fs.rmSync(dest,{recursive:true,force:true});fs.mkdirSync(dest,{recursive:true});fs.cpSync(src,dest,{recursive:true});\"",
    "build": "npm run build:webview && npm run copy:webview && tsc -p .",
    "watch": "tsc -p . --watch"
  },
  "contributes": {
    "commands": [
      {
        "command": "gpilot.commit",
        "title": "gpilot: Generate commit message",
        "category": "gpilot"
      },
      {
        "command": "gpilot.createPR",
        "title": "gpilot: Create PR with description",
        "category": "gpilot"
      },
      {
        "command": "gpilot.reviewPR",
        "title": "gpilot: Review current PR",
        "category": "gpilot"
      },
      {
        "command": "gpilot.fixAllBlockers",
        "title": "gpilot: Fix all blocker comments",
        "category": "gpilot"
      },
      {
        "command": "gpilot.fixComment",
        "title": "gpilot: Fix selected comment",
        "category": "gpilot"
      },
      {
        "command": "gpilot.switchModel",
        "title": "gpilot: Switch AI model",
        "category": "gpilot"
      },
      {
        "command": "gpilot.auth",
        "title": "gpilot: Setup or update API keys",
        "category": "gpilot"
      },
      {
        "command": "gpilot.showPanel",
        "title": "gpilot: Show panel",
        "category": "gpilot"
      },
      {
        "command": "gpilot.status",
        "title": "gpilot: Show status",
        "category": "gpilot"
      },
      {
        "command": "gpilot.toggleMode",
        "title": "gpilot: Toggle between AI and Native Git",
        "category": "gpilot"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gpilot",
          "title": "gpilot",
          "icon": "media/activity-bar.png"
        }
      ]
    },
    "views": {
      "gpilot": [
        {
          "type": "webview",
          "id": "gpilot.panel",
          "name": "gpilot"
        }
      ]
    },
    "menus": {
      "scm/title": [
        {
          "command": "gpilot.commit",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "view/title": []
    },
    "configuration": {
      "title": "gpilot",
      "properties": {
        "gpilot.defaultMode": {
          "type": "string",
          "enum": [
            "gpilot",
            "native"
          ],
          "default": "gpilot",
          "description": "Default sidebar mode on first activation. 'gpilot' uses AI for commit and PR text; 'native' falls back to manual git commands."
        },
        "gpilot.cliCommand": {
          "type": "string",
          "default": "npx gpilot",
          "description": "Command used to invoke the gpilot CLI from the extension. Override if gpilot is installed under a different name or path."
        }
      }
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "keytar": "^7.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^6.0.3"
  }
}
